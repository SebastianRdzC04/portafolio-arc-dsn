---
import type { Term } from '../data/terms';

interface Props {
  term: Term;
  subjectCount: number;
  workCount: number;
  hasSchedule: boolean;
}

const { term, subjectCount, workCount, hasSchedule } = Astro.props;
---

<a href={`/${term.slug}/`} class="term-card" style={`--term-accent: ${term.color}`}>
  <div class="term-card__header">
    <span class="term-card__badge">{term.numeral}</span>
    {hasSchedule && <span class="term-card__schedule">Horario disponible</span>}
  </div>
  <h2 class="term-card__title">{term.name}</h2>
  <p class="term-card__description">{term.description}</p>
  <div class="term-card__meta">
    <span>{term.period}</span>
    <span>{subjectCount} {subjectCount === 1 ? 'materia' : 'materias'}</span>
    <span>{workCount} {workCount === 1 ? 'trabajo' : 'trabajos'}</span>
  </div>
</a>

<style>
  .term-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, var(--color-bg-card), var(--color-bg-alt));
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--transition-normal),
      box-shadow var(--transition-normal),
      transform var(--transition-normal);
  }

  .term-card:hover {
    border-color: var(--term-accent, var(--color-accent));
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .term-card:focus-visible {
    outline: 2px solid var(--term-accent, var(--color-accent));
    outline-offset: 2px;
  }

  .term-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .term-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background-color: var(--term-accent, var(--color-accent));
    color: var(--color-text-inverse);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
  }

  .term-card__schedule {
    font-size: var(--text-xs);
    color: var(--color-accent-dark);
    font-weight: var(--weight-medium);
  }

  .term-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text);
  }

  .term-card__description {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .term-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }
</style>
