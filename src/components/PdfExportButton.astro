---
interface Props {
  href: string;
  title: string;
  label?: string;
  ariaLabel?: string;
  showTextOnMobile?: boolean;
}

const {
  href,
  title,
  label = 'Descargar PDF',
  ariaLabel = `Descargar "${title}" como PDF`,
  showTextOnMobile = false,
} = Astro.props;
---

<div class="pdf-export">
  <a
    class="pdf-export__button"
    href={href}
    aria-label={ariaLabel}
  >
    <svg
      class="pdf-export__icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
      <polyline points="14 2 14 8 20 8"></polyline>
      <line x1="12" y1="13" x2="12" y2="17"></line>
      <line x1="9" y1="15" x2="15" y2="15"></line>
    </svg>
    <span class:list={['pdf-export__text', { 'pdf-export__text--mobile': showTextOnMobile }]}>
      {label}
    </span>
  </a>
</div>

<style>
  .pdf-export {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .pdf-export__button {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background-color: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
    white-space: nowrap;
  }

  .pdf-export__button:hover:not(:disabled) {
    background-color: var(--color-accent-dark);
    transform: translateY(-1px);
  }

  .pdf-export__button:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .pdf-export__icon {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  .pdf-export__text {
    display: none;
  }

  .pdf-export__text--mobile {
    display: inline;
  }

  @media (min-width: 768px) {
    .pdf-export__text {
      display: inline;
    }

    .pdf-export__button {
      padding: var(--space-2) var(--space-4);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pdf-export__button {
      transition: background-color var(--transition-fast);
    }

    .pdf-export__button:hover:not(:disabled) {
      transform: none;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .pdf-export__button {
      padding: var(--space-2);
      font-size: var(--text-xs);
    }

    .pdf-export__icon {
      width: 1.2em;
      height: 1.2em;
    }
  }
</style>
