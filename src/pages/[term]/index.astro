---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SubjectCard from '../../components/SubjectCard.astro';
import { getSubjectsByTerm } from '../../data/subjects';
import { terms } from '../../data/terms';
import { getCollection } from 'astro:content';
import {
  parseContentId,
  parseWorkId,
  isScheduleEntryId,
  isWorkEntryId,
} from '../../lib/utils';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  return terms.map((term) => ({
    params: { term: term.slug },
    props: { term },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { term } = Astro.props as Props;
const termSubjects = getSubjectsByTerm(term.slug);

const allEntries = await getCollection('trabajos', ({ data }) => !data.draft);
const termWorks = allEntries.filter((entry) => {
  if (!isWorkEntryId(entry.id)) {
    return false;
  }

  return parseWorkId(entry.id).term === term.slug;
});

const hasSchedule = allEntries.some((entry) => {
  if (!isScheduleEntryId(entry.id)) {
    return false;
  }

  return parseContentId(entry.id).term === term.slug;
});

const workCountsBySubject = new Map<string, number>();
for (const work of termWorks) {
  const { subject, file } = parseWorkId(work.id);

  if (file !== 'index') {
    continue;
  }

  workCountsBySubject.set(subject, (workCountsBySubject.get(subject) ?? 0) + 1);
}
---

<Layout title={`${term.name} — Portafolio Academico`} description={term.description}>
  <div class="term-page container">
    <Breadcrumbs
      items={[
        { label: 'Inicio', href: '/' },
        { label: term.name },
      ]}
    />

    <header class="term-page__header" style={`--term-accent: ${term.color}`}>
      <div class="term-page__header-top">
        <span class="term-page__badge">{term.numeral}</span>
        {hasSchedule && (
          <a class="term-page__schedule-link" href={`/${term.slug}/horario/`}>
            Ver horario
          </a>
        )}
      </div>
      <h1 class="term-page__title">{term.name}</h1>
      <p class="term-page__description">{term.description}</p>
      <div class="term-page__meta">
        <span>Periodo: {term.period}</span>
        <span>{termSubjects.length} {termSubjects.length === 1 ? 'materia' : 'materias'}</span>
        <span>{workCountsBySubject.size > 0 ? [...workCountsBySubject.values()].reduce((acc, value) => acc + value, 0) : 0} trabajos</span>
      </div>
    </header>

    {termSubjects.length === 0 ? (
      <div class="term-page__empty">
        <p>Aun no hay materias registradas en este cuatrimestre.</p>
      </div>
    ) : (
      <section class="term-page__subjects" aria-labelledby="term-subjects-heading">
        <h2 id="term-subjects-heading" class="term-page__subjects-title">Materias</h2>
        <div class="term-page__subjects-grid">
          {termSubjects.map((subject) => (
            <SubjectCard
              subject={subject}
              workCount={workCountsBySubject.get(subject.slug) ?? 0}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .term-page {
    max-width: var(--max-width);
    padding-top: var(--space-8);
  }

  .term-page__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background:
      radial-gradient(circle at top right, var(--color-accent-bg), transparent 52%),
      linear-gradient(140deg, var(--color-bg-card), var(--color-bg-alt));
  }

  .term-page__header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .term-page__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background-color: var(--term-accent, var(--color-accent));
    color: var(--color-text-inverse);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
  }

  .term-page__schedule-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-card);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .term-page__schedule-link:hover {
    border-color: var(--term-accent, var(--color-accent));
    color: var(--term-accent, var(--color-accent));
    transform: translateY(-1px);
  }

  .term-page__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .term-page__description {
    max-width: var(--max-width-prose);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }

  .term-page__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .term-page__subjects {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .term-page__subjects-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text);
  }

  .term-page__subjects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .term-page__subjects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .term-page__empty {
    padding: var(--space-12) 0;
    text-align: center;
  }

  .term-page__empty p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  @media (max-width: 639px) {
    .term-page__title {
      font-size: var(--text-3xl);
    }
  }
</style>
