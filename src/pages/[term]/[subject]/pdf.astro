---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { subjects } from '../../../data/subjects';
import { getTermBySlug } from '../../../data/terms';
import { getCollection, render } from 'astro:content';
import {
  formatDate,
  groupBy,
  isWorkEntryId,
  parseWorkId,
  slugToLabel,
  sortByOrder,
} from '../../../lib/utils';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

export const prerender = true;

interface SubjectPdfWork {
  entry: CollectionEntry<'trabajos'>;
  parsed: {
    term: string;
    subject: string;
    unit: string;
    work: string;
    file: string;
  };
  Content: Awaited<ReturnType<typeof render>>['Content'];
}

export const getStaticPaths = (async () => {
  return subjects.map((subject) => ({
    params: { term: subject.termSlug, subject: subject.slug },
    props: { subject },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { subject } = Astro.props as Props;
const term = getTermBySlug(subject.termSlug);
const termName = term?.name ?? subject.termSlug;
const isPdf = Astro.url.searchParams.get('pdf') === 'true';

const allEntries = await getCollection('trabajos', ({ data }) => !data.draft);
const allWorks = allEntries.filter((entry) => isWorkEntryId(entry.id));
const subjectWorks = allWorks.filter((work) => {
  const parsed = parseWorkId(work.id);
  return (
    parsed.term === subject.termSlug &&
    parsed.subject === subject.slug &&
    parsed.file === 'index' &&
    !work.data.isSection
  );
});

const sortedSubjectWorks = sortByOrder(subjectWorks);
const renderedWorks: SubjectPdfWork[] = await Promise.all(
  sortedSubjectWorks.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      entry,
      parsed: parseWorkId(entry.id),
      Content,
    };
  }),
);

const workOrderById = new Map<string, number>();
renderedWorks.forEach((work, index) => {
  workOrderById.set(work.entry.id, index);
});

const unitGroups = groupBy(renderedWorks, (work) => work.parsed.unit);
const sortedUnits = [...unitGroups.entries()].sort(([a], [b]) =>
  a.localeCompare(b, undefined, { numeric: true }),
);

function getWorkAnchor(work: SubjectPdfWork): string {
  return `trabajo-${work.parsed.unit}-${work.parsed.work}`;
}
---

<Layout
  title={`${subject.name} — PDF completo`}
  description={`Compendio de trabajos de ${subject.name}.`}
  isPdf={isPdf}
>
  <div class:list={['subject-pdf', 'container', { 'subject-pdf--pdf': isPdf }]}>
    {!isPdf && (
      <Breadcrumbs
        items={[
          { label: 'Inicio', href: '/' },
          { label: termName, href: `/${subject.termSlug}/` },
          { label: subject.name, href: `/${subject.termSlug}/${subject.slug}/` },
          { label: 'PDF completo' },
        ]}
      />
    )}

    <header class="subject-pdf__header" style={`--subject-accent: ${subject.color}`}>
      <span class="subject-pdf__badge">{subject.shortName}</span>
      <h1 class="subject-pdf__title">Compendio de trabajos</h1>
      <p class="subject-pdf__description">
        Documento consolidado con todas las evidencias de {subject.name}.
      </p>
      <div class="subject-pdf__meta">
        <span>{termName}</span>
        <span>Periodo: {subject.semester}</span>
        <span>
          {renderedWorks.length} {renderedWorks.length === 1 ? 'trabajo' : 'trabajos'}
        </span>
      </div>
    </header>

    {sortedUnits.length === 0 ? (
      <div class="subject-pdf__empty">
        <p>Aun no hay trabajos publicados para esta materia.</p>
      </div>
    ) : (
      <>
        <section class="subject-pdf__index" aria-labelledby="indice-trabajos">
          <h2 id="indice-trabajos" class="subject-pdf__index-title">Indice</h2>
          <ol class="subject-pdf__index-list" role="list">
            {sortedUnits.map(([unitSlug, works]) => (
              <li class="subject-pdf__index-unit">
                <h3 class="subject-pdf__index-unit-title">{slugToLabel(unitSlug)}</h3>
                <ol class="subject-pdf__index-works" role="list">
                  {works.map((work) => (
                    <li class="subject-pdf__index-work-item">
                      <a class="subject-pdf__index-link" href={`#${getWorkAnchor(work)}`}>
                        {work.entry.data.title}
                      </a>
                    </li>
                  ))}
                </ol>
              </li>
            ))}
          </ol>
        </section>

        <section class="subject-pdf__works" aria-label="Trabajos de la materia">
          {sortedUnits.map(([unitSlug, works]) => (
            <section class="subject-pdf__unit" aria-labelledby={`unidad-${unitSlug}`}>
              <h2 id={`unidad-${unitSlug}`} class="subject-pdf__unit-title">
                {slugToLabel(unitSlug)}
              </h2>

              {works.map((work) => (
                <article
                  id={getWorkAnchor(work)}
                  class:list={[
                    'subject-pdf__work',
                    {
                      'subject-pdf__work--page-break': (workOrderById.get(work.entry.id) ?? 0) > 0,
                    },
                  ]}
                >
                  <header class="subject-pdf__work-header">
                    <div class="subject-pdf__work-meta">
                      <time datetime={work.entry.data.date.toISOString()}>
                        {formatDate(work.entry.data.date)}
                      </time>
                      {work.entry.data.tags && work.entry.data.tags.length > 0 && (
                        <div class="subject-pdf__work-tags">
                          {work.entry.data.tags.map((tag) => (
                            <span class="subject-pdf__work-tag">{tag}</span>
                          ))}
                        </div>
                      )}
                    </div>
                    <h3 class="subject-pdf__work-title">{work.entry.data.title}</h3>
                    <p class="subject-pdf__work-description">{work.entry.data.description}</p>
                  </header>

                  <div class="subject-pdf__work-content prose">
                    <work.Content />
                  </div>
                </article>
              ))}
            </section>
          ))}
        </section>
      </>
    )}
  </div>
</Layout>

<style>
  .subject-pdf {
    max-width: var(--max-width-narrow);
    padding-top: var(--space-8);
  }

  .subject-pdf--pdf {
    max-width: 840px;
    padding-top: var(--space-6);
    margin: 0 auto;
  }

  .subject-pdf__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .subject-pdf__badge {
    display: inline-flex;
    align-self: flex-start;
    padding: var(--space-1) var(--space-3);
    background-color: var(--subject-accent, var(--color-accent));
    color: var(--color-text-inverse);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--radius-full);
  }

  .subject-pdf__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .subject-pdf__description {
    max-width: var(--max-width-prose);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .subject-pdf__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .subject-pdf__index {
    margin-bottom: var(--space-10);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-card);
  }

  .subject-pdf__index-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
  }

  .subject-pdf__index-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style-type: decimal;
    padding-left: var(--space-5);
  }

  .subject-pdf__index-unit {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .subject-pdf__index-unit-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .subject-pdf__index-works {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style-type: decimal;
    padding-left: var(--space-5);
  }

  .subject-pdf__index-work-item {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .subject-pdf__index-link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .subject-pdf__index-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .subject-pdf__works {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .subject-pdf__unit {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .subject-pdf__unit-title {
    font-size: var(--text-2xl);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .subject-pdf__work {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .subject-pdf__work--page-break {
    page-break-before: always;
    break-before: page;
  }

  .subject-pdf__work-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .subject-pdf__work-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .subject-pdf__work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .subject-pdf__work-tag {
    padding: 2px var(--space-2);
    background-color: var(--color-accent-bg);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
  }

  .subject-pdf__work-title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .subject-pdf__work-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: var(--max-width-prose);
  }

  .subject-pdf__work-content :global(h1),
  .subject-pdf__work-content :global(h2),
  .subject-pdf__work-content :global(h3),
  .subject-pdf__work-content :global(h4),
  .subject-pdf__work-content :global(h5),
  .subject-pdf__work-content :global(h6) {
    font-family: var(--font-heading);
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .subject-pdf__work-content :global(h2) {
    font-size: var(--text-2xl);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .subject-pdf__work-content :global(h3) {
    font-size: var(--text-xl);
  }

  .subject-pdf__work-content :global(p) {
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: var(--max-width-prose);
  }

  .subject-pdf__work-content :global(ul),
  .subject-pdf__work-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
    max-width: var(--max-width-prose);
  }

  .subject-pdf__work-content :global(ul) {
    list-style-type: disc;
  }

  .subject-pdf__work-content :global(ol) {
    list-style-type: decimal;
  }

  .subject-pdf__work-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .subject-pdf__work-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .subject-pdf__work-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .subject-pdf__work-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-6) 0;
  }

  .subject-pdf__work-content :global(p:has(> img)) {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  .subject-pdf__work-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-size: var(--text-sm);
    overflow-x: auto;
    display: block;
  }

  .subject-pdf__work-content :global(th),
  .subject-pdf__work-content :global(td) {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .subject-pdf__work-content :global(th) {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    background-color: var(--color-bg-alt);
  }

  .subject-pdf__work-content :global(td) {
    color: var(--color-text-secondary);
  }

  .subject-pdf__work-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  .subject-pdf__work-content :global(pre) {
    margin: var(--space-6) 0;
    overflow-x: auto;
  }

  .subject-pdf__work-content :global(strong) {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .subject-pdf__empty {
    padding: var(--space-12) 0;
    text-align: center;
  }

  .subject-pdf__empty p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  @media (max-width: 639px) {
    .subject-pdf__title,
    .subject-pdf__work-title {
      font-size: var(--text-3xl);
    }
  }

  @media print {
    .subject-pdf {
      max-width: 100%;
      padding-top: 0;
    }

    .subject-pdf__index {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .subject-pdf__works {
      page-break-before: always;
      break-before: page;
    }

    .subject-pdf__work-content :global(img),
    .subject-pdf__work-content :global(figure),
    .subject-pdf__work-content :global(pre),
    .subject-pdf__work-content :global(table),
    .subject-pdf__work-content :global(blockquote),
    .subject-pdf__work-content :global(.no-break) {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .subject-pdf__work-content :global(h1),
    .subject-pdf__work-content :global(h2),
    .subject-pdf__work-content :global(h3) {
      page-break-after: avoid;
    }

    .subject-pdf__work-content :global(p) {
      orphans: 3;
      widows: 3;
    }
  }
</style>
